<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Register</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --surface-strong: rgba(255, 255, 255, 0.92);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 24px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero,
  .panel {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
    padding: 18px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(30px, 10vw, 42px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  p {
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
    margin-top: 10px;
  }

  .field-grid {
    display: grid;
    gap: 14px;
  }

  .field label {
    display: block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .field input {
    width: 100%;
    min-height: 50px;
    padding: 13px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 112, 176, 0.18);
    background: var(--surface-strong);
    color: var(--text);
  }

  .btn-row {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 50px;
    border: none;
    border-radius: 18px;
    color: white;
    font-weight: 800;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent), #ff8a85);
    box-shadow: 0 14px 26px rgba(255, 94, 178, 0.26);
  }

  .btn.ghost {
    color: var(--text);
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(255, 112, 176, 0.16);
    box-shadow: none;
  }

  .panel-links {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .panel-links a {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-dim);
  }

  @media (min-width: 768px) {
    .btn-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow">Account</div>
      <h1>Create your waypoint identity.</h1>
      <p>Make an account to save personal spots, receive shared places, and explore public discoveries with your own profile.</p>
    </section>

    <section class="panel">
      <form id="regForm" onsubmit="event.preventDefault(); register();">
        <div class="field-grid">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="you@example.com" autocomplete="email" required>
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" placeholder="Choose a password" autocomplete="new-password" required>
          </div>
        </div>

        <div class="btn-row">
          <a class="btn ghost" href="/account">Back to account</a>
          <button class="btn" onclick="register()" type="button">Create account</button>
        </div>
      </form>

      <div class="panel-links">
        <a href="/auth/login">Already have an account? Log in here.</a>
        <a href="/">Return to compass home</a>
      </div>
    </section>
  </main>

  <script type="module" src="/index.js"></script>
</body>
</html>
