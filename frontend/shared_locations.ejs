<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Shared Locations</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --surface-strong: rgba(255, 255, 255, 0.92);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --text-faint: rgba(74, 47, 103, 0.48);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 108px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .shell {
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero,
  .panel,
  .spot-card {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .hero,
  .panel,
  .spot-card {
    padding: 18px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(30px, 10vw, 42px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  p {
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
  }

  .spot-cards-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .spot-card .name {
    font-size: 18px;
    font-weight: 800;
  }

  .spot-card .meta {
    color: var(--text-dim);
    font-size: 12px;
    margin-top: 6px;
    line-height: 1.55;
  }

  .coordinates {
    font-family: "SF Mono", "Monaco", monospace;
    font-size: 11px;
  }

  .row {
    display: grid;
    margin-top: 14px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 18px;
    color: white;
    font-weight: 800;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent-2), #36d3a0);
    box-shadow: 0 14px 26px rgba(89, 215, 255, 0.26);
  }

  .empty {
    color: var(--text-faint);
    font-size: 13px;
  }

  .bottom-tabs {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 20;
  }

  .tab-bar {
    max-width: 440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 10px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 45px rgba(129, 106, 177, 0.15);
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    font-size: 12px;
    font-weight: 800;
  }

  .tab-item.active {
    background: linear-gradient(135deg, rgba(255, 94, 178, 0.92), rgba(89, 215, 255, 0.92));
    color: white;
  }
</style>
</head>

<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow">Shared</div>
      <h1>Spots from friends.</h1>
      <p>Browse places your friends sent you, then jump straight into compass mode when one catches your eye.</p>
    </section>

    <section class="panel">
      <div class="eyebrow">Inbox</div>
      <h2 style="margin-top:8px;">Shared locations</h2>
      <div id="locationPortal" style="margin-top:14px;"></div>
    </section>
  </main>

  <nav class="bottom-tabs" aria-label="Primary">
    <div class="tab-bar">
      <a class="tab-item" href="/">
        <span>🧭</span>
        <span>Compass</span>
      </a>
      <a class="tab-item" href="/friend">
        <span>👥</span>
        <span>Friends</span>
      </a>
      <a class="tab-item active" href="/location/share">
        <span>✨</span>
        <span>Shared</span>
      </a>
      <a class="tab-item" href="/account">
        <span>⚙️</span>
        <span>Account</span>
      </a>
    </div>
  </nav>
</body>
<script>
window.addEventListener("DOMContentLoaded", () => {
  LoadLocations();
});

async function LoadLocations(){
  const token = localStorage.getItem("access-token");
  const meRes = await fetch("/auth/me", {
    method: "GET",
    headers: {
      "Content-Type": "application/json",
      "authorization": `Bearer ${token}`
    }
  });
  const meData = await meRes.json();
  const userId = meData.userId;

  try {
    const res = await fetch(`/location/share/${userId}`, {
      method: "GET",
      headers: { "Content-Type": "application/json" }
    });

    const locations = await res.json();
    const container = document.querySelector("#locationPortal");
    container.innerHTML = "";

    const cardsContainer = document.createElement("div");
    cardsContainer.className = "spot-cards-container";

    if (!locations || locations.length === 0) {
      container.innerHTML = '<p class="empty">No shared locations yet.</p>';
      return;
    }

    for (const loc of locations) {
      const dateStr = new Date(loc.created_at).toLocaleString() || "Date unknown";
      const card = document.createElement("div");
      card.className = "spot-card saved-location";

      card.innerHTML = `
        <div class="name">${loc.name}</div>
        <div class="meta">
          <div>Saved ${dateStr}</div>
          <div class="coordinates">${loc.lat.toFixed(6)}, ${loc.lng.toFixed(6)}</div>
        </div>
        <div class="row">
          <button class="btn" onclick="findLocation(${loc.lat}, ${loc.lng}, '${loc.name}')">Find</button>
        </div>
      `;

      cardsContainer.appendChild(card);
    }

    container.appendChild(cardsContainer);
  } catch (err) {
    console.error("Error loading locations:", err);
    const container = document.querySelector("#locationPortal");
    container.innerHTML = '<p class="empty">Failed to load shared locations.</p>';
  }
}
</script>
<script type="module" src="/index.js"></script>
</html>
