<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Social</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --text-faint: rgba(74, 47, 103, 0.48);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --success: #42ca84;
    --danger: #ff6b7d;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html, body {
    min-height: 100%;
  }

  body {
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 108px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero,
  .panel,
  .card {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .hero,
  .panel {
    padding: 18px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(30px, 10vw, 42px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  p {
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
  }

  .search-row {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  input {
    width: 100%;
    min-height: 48px;
    border: 1px solid rgba(255, 112, 176, 0.18);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
    padding: 13px 14px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 18px;
    color: white;
    font-weight: 800;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent), #ff8a85);
    box-shadow: 0 14px 26px rgba(255, 94, 178, 0.26);
  }

  .btn.reject {
    background: rgba(255, 255, 255, 0.74);
    color: var(--text);
    box-shadow: none;
  }

  .btn.accept {
    background: linear-gradient(135deg, var(--accent-2), var(--success));
  }

  .btn.remove {
    background: linear-gradient(135deg, #ff8a85, var(--danger));
  }

  .btn.find {
    background: linear-gradient(135deg, var(--accent-2), #36d3a0);
  }

  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .section-title h2 {
    font-size: 20px;
  }

  .section-note {
    font-size: 12px;
    color: var(--text-faint);
  }

  .card {
    padding: 14px;
    margin-bottom: 12px;
  }

  .name {
    font-size: 17px;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .meta {
    color: var(--text-dim);
    font-size: 12px;
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .coordinates {
    font-family: "SF Mono", "Monaco", monospace;
    font-size: 11px;
  }

  .butt {
    display: grid;
    gap: 10px;
  }

  .empty {
    color: var(--text-faint);
    font-size: 13px;
  }

  .bottom-tabs {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 20;
  }

  .tab-bar {
    max-width: 440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 10px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 45px rgba(129, 106, 177, 0.15);
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    font-size: 12px;
    font-weight: 800;
  }

  .tab-item.active {
    background: linear-gradient(135deg, rgba(255, 94, 178, 0.92), rgba(89, 215, 255, 0.92));
    color: white;
  }

  @media (min-width: 768px) {
    .search-row,
    .butt {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow">Social</div>
      <h1>Your people.</h1>
      <p>Keep friend requests and your circle management in one place.</p>
      <form id="friend" class="search-row">
        <input type="text" id="friendName" name="friendName" placeholder="Enter a username" required>
        <button class="btn search" type="submit">Send request</button>
      </form>
    </section>

    <section class="panel" id="pending">
      <div class="section-title">
        <h2>Pending requests</h2>
        <span class="section-note">Incoming invites</span>
      </div>
    </section>

    <section class="panel" id="friendsSection">
      <div class="section-title">
        <h2>Your friends</h2>
        <span class="section-note">People in your circle</span>
      </div>
    </section>
  </main>

  <nav class="bottom-tabs" aria-label="Primary">
    <div class="tab-bar">
      <a class="tab-item" href="/">
        <span>🧭</span>
        <span>Compass</span>
      </a>
      <a class="tab-item" href="/drops">
        <span>📍</span>
        <span>Drops</span>
      </a>
      <a class="tab-item active" href="/friend">
        <span>👥</span>
        <span>Social</span>
      </a>
      <a class="tab-item" href="/account">
        <span>⚙️</span>
        <span>Account</span>
      </a>
    </div>
  </nav>
</body>
<script>
document.getElementById("friend").addEventListener("submit", async (e) => {
  e.preventDefault();
  await searchFriend();
});

async function searchFriend() {
  const username = document.getElementById("friendName").value;
  const token = localStorage.getItem("access-token");

  if (!token) {
    alert("Sign in to connect with others");
    return;
  }

  const res = await fetch("/friend/request", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    },
    body: JSON.stringify({ username })
  });

  const result = await res.json();
  if (res.ok) {
    alert("Friend request sent");
    document.getElementById("friendName").value = "";
  } else {
    alert(result.error);
  }
}

async function LoadSocial() {
  const token = localStorage.getItem("access-token");
  if (!token) {
    alert("Sign in to connect with others");
    return console.log("No token found");
  }

  const meRes = await fetch("/auth/me", {
    method: "GET",
    headers: { "Authorization": `Bearer ${token}` }
  });
  const meData = await meRes.json();
  const userId = meData.userId;

  await Promise.all([
    loadPending(token, userId),
    loadAccept(token, userId)
  ]);
}

async function loadPending(token, userId) {
  try {
    const res = await fetch(`/friend/pending/${userId}`, {
      method: "GET",
      headers: { "Content-Type": "application/json" }
    });
    const pendingList = await res.json();

    const container = document.querySelector("#pending");
    const requestsContainer = container.querySelector(".pending-requests") || document.createElement("div");
    requestsContainer.className = "pending-requests";
    requestsContainer.innerHTML = "";

    if (!pendingList || pendingList.length === 0) {
      const status = document.createElement("p");
      status.className = "empty";
      status.innerText = "No pending friend requests.";
      requestsContainer.appendChild(status);
    } else {
      for (const friend of pendingList) {
        const card = document.createElement("div");
        card.className = "card";

        const nameRes = await fetch(`/auth/${friend.user_id}`, {
          method: "GET",
          headers: { "Content-Type": "application/json" }
        });
        const nameData = await nameRes.json();

        card.innerHTML = `
          <div class="name">${nameData.username}</div>
          <div class="butt">
            <button class="btn accept" onclick="acceptFriend('${friend.id}')">Accept</button>
            <button class="btn reject" onclick="rejectFriend('${friend.id}')">Reject</button>
          </div>
        `;

        requestsContainer.appendChild(card);
      }
    }

    if (!container.querySelector(".pending-requests")) {
      container.appendChild(requestsContainer);
    }
  } catch (error) {
    console.error("Error loading pending requests:", error);
    const container = document.querySelector("#pending");
    container.innerHTML += '<p class="empty">Failed to load pending requests.</p>';
  }
}

async function loadAccept(token, userId) {
  try {
    const res = await fetch(`/friend/${userId}`, {
      method: "GET",
      headers: { "Content-Type": "application/json" }
    });
    const friendList = await res.json();

    const container = document.querySelector("#friendsSection");
    const friendsContainer = container.querySelector(".friends-list") || document.createElement("div");
    friendsContainer.className = "friends-list";
    friendsContainer.innerHTML = "";

    if (!friendList || friendList.length === 0) {
      const status = document.createElement("p");
      status.className = "empty";
      status.innerText = "No friends yet.";
      friendsContainer.appendChild(status);
    } else {
      for (const friend of friendList) {
        const card = document.createElement("div");
        card.className = "card";
        const searchId = friend.user_id === userId ? friend.friend_id : friend.user_id;

        const nameRes = await fetch(`/auth/${searchId}`, {
          method: "GET",
          headers: { "Content-Type": "application/json" }
        });
        const nameData = await nameRes.json();

        card.innerHTML = `
          <div class="name">${nameData.username}</div>
          <div class="butt">
            <button class="btn remove" onclick="removeFriend('${friend.id}')">Remove</button>
          </div>
        `;

        friendsContainer.appendChild(card);
      }
    }

    if (!container.querySelector(".friends-list")) {
      container.appendChild(friendsContainer);
    }
  } catch (error) {
    console.error("Error loading friends:", error);
    const container = document.querySelector("#friendsSection");
    container.innerHTML += '<p class="empty">Failed to load friends.</p>';
  }
}

async function acceptFriend(requestId) {
  const token = localStorage.getItem("access-token");
  const res = await fetch("/friend/accept", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    },
    body: JSON.stringify({ requestId })
  });
  const result = await res.json();
  if (res.ok) {
    alert("Friend request accepted");
    await LoadSocial();
  } else {
    alert(result.error);
  }
}

async function rejectFriend(requestId) {
  const token = localStorage.getItem("access-token");
  const res = await fetch("/friend/reject", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    },
    body: JSON.stringify({ requestId })
  });
  const result = await res.json();
  if (res.ok) {
    alert(result.message || "Request removed");
    await LoadSocial();
  } else {
    alert(result.error);
  }
}

async function removeFriend(friendId) {
  const token = localStorage.getItem("access-token");
  const res = await fetch("/friend/remove", {
    method: "DELETE",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    },
    body: JSON.stringify({ friendId })
  });
  const result = await res.json();
  if (res.ok) {
    alert(result.message || "Friend removed");
    await LoadSocial();
  } else {
    alert(result.error);
  }
}

window.addEventListener("DOMContentLoaded", () => {
  LoadSocial();
});
</script>
</html>
