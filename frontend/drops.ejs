<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Drops</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --text-faint: rgba(74, 47, 103, 0.48);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --accent-3: #ffd84f;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 108px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select {
    font: inherit;
  }

  .shell {
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero,
  .panel,
  .spot-card {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
    overflow: visible;
  }

  .hero,
  .panel,
  .spot-card {
    padding: 18px;
  }

  .panel {
    position: relative;
  }

  .panel.menu-open {
    z-index: 30;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(30px, 10vw, 42px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  h2 {
    font-size: 20px;
  }

  p {
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
  }

  .field-grid {
    display: grid;
    gap: 12px;
    margin-top: 14px;
  }

  .field label {
    display: block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .field input,
  .location-category {
    width: 100%;
    min-height: 48px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--text);
    border: 1px solid rgba(255, 112, 176, 0.18);
    border-radius: 16px;
    padding: 13px 14px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 18px;
    color: white;
    font-weight: 800;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent), #ff8a85);
    box-shadow: 0 14px 26px rgba(255, 94, 178, 0.26);
  }

  .btn.ghost {
    color: var(--text);
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 112, 176, 0.16);
    box-shadow: none;
  }

  .btn.find {
    background: linear-gradient(135deg, var(--accent-2), #36d3a0);
  }

  .btn.spark {
    background: linear-gradient(135deg, var(--accent-3), #ffb84f);
    color: var(--text);
    box-shadow: 0 14px 26px rgba(255, 199, 71, 0.25);
  }

  .status {
    min-height: 18px;
    color: var(--text-dim);
    font-size: 13px;
    line-height: 1.45;
  }

  .status.error {
    color: #ff6b7d;
  }

  .saved-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .saved-header .btn {
    width: auto;
    padding: 0 16px;
    min-height: 42px;
  }

  #locationPortal {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: visible;
  }

  .spot-cards-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: visible;
  }

  .spot-card.menu-open {
    z-index: 20;
  }

  .spot-card .name {
    font-size: 18px;
    font-weight: 800;
    flex: 1;
    min-width: 0;
  }

  .spot-card .meta {
    color: var(--text-dim);
    font-size: 12px;
    line-height: 1.55;
    margin-top: 7px;
  }

  .spot-card .coordinates {
    font-family: "SF Mono", "Monaco", monospace;
    font-size: 11px;
  }

  .spot-card .row {
    display: flex;
    gap: 10px;
    margin-top: 14px;
  }

  .spot-card .row .btn {
    max-width: 180px;
  }

  .spot-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .card-menu {
    position: relative;
    flex: 0 0 auto;
  }

  .card-menu-trigger {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    border: 1px solid rgba(255, 112, 176, 0.16);
    background: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(175, 106, 180, 0.08);
  }

  .card-menu-trigger span {
    transform: translateY(-2px);
  }

  .card-menu-panel {
    position: absolute;
    top: 48px;
    right: 0;
    width: min(250px, 72vw);
    min-width: 220px;
    padding: 12px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 40px rgba(130, 92, 160, 0.18);
    display: none;
    gap: 10px;
    z-index: 10;
  }

  .card-menu.open .card-menu-panel {
    display: grid;
  }

  .menu-action {
    width: 100%;
    border: none;
    background: rgba(255, 255, 255, 0.7);
    color: var(--text);
    text-align: left;
    padding: 12px 14px;
    border-radius: 14px;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid rgba(255, 112, 176, 0.12);
  }

  .menu-action.danger {
    color: #ff6b7d;
  }

  .menu-label {
    font-size: 12px;
    font-weight: 800;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: -2px;
  }

  .bottom-tabs {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 20;
  }

  .tab-bar {
    max-width: 440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 10px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 45px rgba(129, 106, 177, 0.15);
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    font-size: 12px;
    font-weight: 800;
  }

  .tab-item.active {
    background: linear-gradient(135deg, rgba(255, 94, 178, 0.92), rgba(89, 215, 255, 0.92));
    color: white;
  }
</style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow">Drops</div>
      <h1>Save your own points.</h1>
      <p>Quick-save from the plus button or manage all your saved waypoints here in one dedicated tab.</p>
    </section>

    <section class="panel">
      <div class="eyebrow">New Drop</div>
      <div class="field-grid">
        <div class="field">
          <label for="spotName">Spot name</label>
          <input id="spotName" name="spotName" type="text" placeholder="Parked bike, cafe, campsite..." maxlength="40" autocomplete="off" required>
        </div>
        <button class="btn spark" id="saveBtn" onclick="saveLocation()" type="button">Save this spot</button>
        <div class="status" id="homeStatus"></div>
      </div>
    </section>

    <section class="panel">
      <div class="saved-header">
        <div>
          <div class="eyebrow">Collection</div>
          <h2>Saved locations</h2>
        </div>
        <button id="loadLocation" class="btn ghost" type="button" onclick="loadLocations()">Refresh</button>
      </div>
      <div id="locationPortal">Tap refresh to load your saved spots.</div>
    </section>

    <section class="panel">
      <div class="saved-header">
        <div>
          <h2>Shared with you</h2>
        </div>
      </div>
      <div id="sharedPortal">Loading shared spots...</div>
    </section>
  </main>

  <nav class="bottom-tabs" aria-label="Primary">
    <div class="tab-bar">
      <a class="tab-item" href="/">
        <span>🧭</span>
        <span>Compass</span>
      </a>
      <a class="tab-item active" href="/drops">
        <span>📍</span>
        <span>Drops</span>
      </a>
      <a class="tab-item" href="/friend">
        <span>👥</span>
        <span>Social</span>
      </a>
      <a class="tab-item" href="/account">
        <span>⚙️</span>
        <span>Account</span>
      </a>
    </div>
  </nav>

  <script type="module" src="/index.js"></script>
  <script>
    function openFinder(loc) {
      const targetSpot = {
        id: loc.id || null,
        is_public: !!loc.is_public,
        name: loc.name || "Shared location",
        lat: parseFloat(loc.lat),
        lng: parseFloat(loc.lng),
        accuracy: 0,
        ts: Date.now()
      };
      sessionStorage.setItem("pendingTargetSpot", JSON.stringify(targetSpot));
      window.location.href = "/";
    }

    async function loadSharedLocations() {
      const token = localStorage.getItem("access-token");
      const container = document.getElementById("sharedPortal");
      if (!token) {
        container.innerHTML = '<p class="empty">Sign in to view shared spots.</p>';
        return;
      }

      try {
        const meRes = await fetch("/auth/me", {
          method: "GET",
          headers: { "Authorization": `Bearer ${token}` }
        });
        const meData = await meRes.json();
        if (!meRes.ok) throw new Error(meData.error || "Unable to verify your session");

        const res = await fetch(`/location/share/${meData.userId}`, {
          method: "GET",
          headers: { "Content-Type": "application/json" }
        });
        const locations = await res.json();
        if (!res.ok) throw new Error(locations.error || "Failed to load shared spots");

        container.innerHTML = "";

        if (!locations || locations.length === 0) {
          container.innerHTML = '<p class="empty">No shared spots yet.</p>';
          return;
        }

        const cardsContainer = document.createElement("div");
        cardsContainer.className = "spot-cards-container";

        for (const loc of locations) {
          const dateStr = new Date(loc.shared_at || loc.created_at).toLocaleString() || "Date unknown";
          const sharedBy = loc.shared_by_username ? `Shared by ${loc.shared_by_username}` : "Shared by a friend";
          const card = document.createElement("div");
          card.className = "spot-card";
          card.innerHTML = `
            <div class="name">${loc.name}</div>
            <div class="meta">
              <div>${sharedBy}</div>
              <div>Shared ${dateStr}</div>
              <div class="coordinates">${Number(loc.lat).toFixed(6)}, ${Number(loc.lng).toFixed(6)}</div>
            </div>
            <div class="row">
              <button class="btn find" type="button">Open compass</button>
              <button class="btn ghost remove-shared" type="button">Remove</button>
            </div>
          `;
          card.querySelector(".find").addEventListener("click", () => openFinder(loc));
          card.querySelector(".remove-shared").addEventListener("click", () => removeSharedLocation(loc.share_id));
          cardsContainer.appendChild(card);
        }

        container.appendChild(cardsContainer);
      } catch (error) {
        console.error("Error loading shared spots:", error);
        container.innerHTML = `<p class="empty">${error.message || "Failed to load shared spots."}</p>`;
      }
    }

    window.addEventListener("DOMContentLoaded", () => {
      loadLocations();
      loadSharedLocations();
    });

    async function removeSharedLocation(shareId) {
      const token = localStorage.getItem("access-token");
      if (!token) {
        alert("Sign in to manage shared spots.");
        return;
      }

      if (!shareId) {
        alert("This shared location is missing its share record.");
        return;
      }

      if (!confirm("Remove this shared spot from your list?")) {
        return;
      }

      const res = await fetch(`/location/share/${shareId}`, {
        method: "DELETE",
        headers: {
          "Authorization": `Bearer ${token}`
        }
      });
      const result = await res.json();

      if (!res.ok) {
        alert(result.error || "Failed to remove shared spot.");
        return;
      }

      loadSharedLocations();
    }
  </script>
</body>
</html>
