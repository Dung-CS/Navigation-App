<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Account</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --text-faint: rgba(74, 47, 103, 0.48);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --danger: #ff6b7d;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 108px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .shell {
    max-width: 440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero,
  .panel {
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface);
    border-radius: 28px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
    padding: 18px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(30px, 10vw, 42px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  .hero-copy {
    margin-top: 10px;
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
  }

  .hero-actions {
    display: none;
    gap: 10px;
    margin-top: 18px;
  }

  h2 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  p {
    color: var(--text-dim);
    line-height: 1.5;
    font-size: 14px;
  }

  .btn-row,
  .setting-list {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border: none;
    border-radius: 18px;
    color: white;
    font-weight: 800;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent), #ff8a85);
    box-shadow: 0 14px 26px rgba(255, 94, 178, 0.26);
  }

  .btn.ghost {
    color: var(--text);
    background: rgba(255, 255, 255, 0.74);
    box-shadow: none;
    border: 1px solid rgba(255, 112, 176, 0.16);
  }

  .btn.warn {
    background: linear-gradient(135deg, #ff8a85, var(--danger));
  }

  .setting-item {
    padding: 14px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.84);
  }

  .setting-item strong {
    display: block;
    font-size: 15px;
    margin-bottom: 4px;
  }

  .status {
    min-height: 18px;
    color: var(--text-dim);
    font-size: 13px;
  }

  .status.error {
    color: var(--danger);
  }

  .bottom-tabs {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 20;
  }

  .tab-bar {
    max-width: 440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 10px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 45px rgba(129, 106, 177, 0.15);
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 64px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    font-size: 12px;
    font-weight: 800;
  }

  .tab-item.active {
    background: linear-gradient(135deg, rgba(255, 94, 178, 0.92), rgba(89, 215, 255, 0.92));
    color: white;
  }

  @media (min-width: 768px) {
    .btn-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <div class="eyebrow">Account</div>
      <h1 id="accountHeroTitle">Hi there</h1>
      <p class="hero-copy" id="accountHeroCopy">Sign in to manage friends, saved spots, and shared locations from one place.</p>
      <div class="btn-row hero-actions" id="signedInActions">
        <a class="btn ghost" href="/friend">Open social</a>
        <button class="btn warn" type="button" onclick="logout()">Logout</button>
      </div>
    </section>

    <section class="panel" id="accountAccessPanel">
      <div id="signedOutView">
        <h2>Sign in or create an account</h2>
        <p>Use your account to save spots across sessions, manage friends, and see locations shared with you.</p>
        <div class="btn-row">
          <a class="btn ghost" href="/auth/register">Register</a>
          <a class="btn" href="/auth/login">Login</a>
        </div>
      </div>

      <div class="status" id="accountStatus"></div>
    </section>

  </main>

  <nav class="bottom-tabs" aria-label="Primary">
    <div class="tab-bar">
      <a class="tab-item" href="/">
        <span>🧭</span>
        <span>Compass</span>
      </a>
      <a class="tab-item" href="/drops">
        <span>📍</span>
        <span>Drops</span>
      </a>
      <a class="tab-item" href="/friend">
        <span>👥</span>
        <span>Social</span>
      </a>
      <a class="tab-item active" href="/account">
        <span>⚙️</span>
        <span>Account</span>
      </a>
    </div>
  </nav>

  <script>
    function setSignedInState(username) {
      document.getElementById("accountHeroTitle").innerText = username ? `Hi, ${username}` : "Hi there";
      document.getElementById("accountHeroCopy").innerText = "Your account is active. You can manage friends, saved spots, and shared locations from here.";
      document.getElementById("signedOutView").style.display = "none";
      document.getElementById("signedInActions").style.display = "grid";
      document.getElementById("accountAccessPanel").style.display = "none";
      document.getElementById("accountStatus").textContent = "";
      document.getElementById("accountStatus").classList.remove("error");
    }

    function setSignedOutState(message, isError) {
      document.getElementById("accountHeroTitle").innerText = "Account";
      document.getElementById("accountHeroCopy").innerText = "Sign in to manage friends, saved spots, and shared locations from one place.";
      document.getElementById("signedOutView").style.display = "block";
      document.getElementById("signedInActions").style.display = "none";
      document.getElementById("accountAccessPanel").style.display = "block";
      const status = document.getElementById("accountStatus");
      status.textContent = message || "";
      status.classList.toggle("error", !!isError);
    }

    async function checkSession() {
      const token = localStorage.getItem("access-token");
      if (!token) {
        setSignedOutState("You are currently signed out.");
        return false;
      }

      try {
        const response = await fetch("/auth/username", {
          method: "GET",
          headers: {
            "Authorization": `Bearer ${token}`
          }
        });

        if (response.ok) {
          const result = await response.json();
          setSignedInState(result.username);
          return true;
        }

        localStorage.removeItem("access-token");
        setSignedOutState("Your session expired. Please sign in again.", true);
        return false;
      } catch (err) {
        console.error("Error checking account session:", err);
        setSignedOutState("We could not verify your session right now.", true);
        return false;
      }
    }

    async function logout() {
      const token = localStorage.getItem("access-token");
      if (!token) {
        setSignedOutState("You are already signed out.");
        return;
      }

      try {
        const response = await fetch("/auth/logout", {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${token}`
          }
        });

        if (!response.ok) {
          throw new Error("Logout failed");
        }

        localStorage.removeItem("access-token");
        setSignedOutState("You have been logged out.");
      } catch (err) {
        console.error("Unexpected error during logout:", err);
        setSignedOutState("Logout failed. Please try again.", true);
      }
    }

    window.addEventListener("DOMContentLoaded", () => {
      checkSession();
    });
  </script>
</body>
</html>
