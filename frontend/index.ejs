<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Waypoint</title>
<style>
  :root {
    --bg-top: #fff6cb;
    --bg-mid: #ffd3ea;
    --bg-bottom: #b6f2ff;
    --surface: rgba(255, 255, 255, 0.78);
    --surface-strong: rgba(255, 255, 255, 0.92);
    --surface-soft: rgba(255, 255, 255, 0.58);
    --line: rgba(255, 110, 168, 0.18);
    --text: #4a2f67;
    --text-dim: rgba(74, 47, 103, 0.72);
    --text-faint: rgba(74, 47, 103, 0.48);
    --accent: #ff5eb2;
    --accent-2: #59d7ff;
    --accent-3: #ffd84f;
    --success: #42ca84;
    --danger: #ff6b7d;
    --shadow: 0 18px 50px rgba(175, 106, 180, 0.16);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html, body {
    height: 100%;
  }

  body {
    min-height: 100%;
    background:
      radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.78), transparent 22%),
      radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.62), transparent 18%),
      radial-gradient(circle at 75% 70%, rgba(255, 244, 181, 0.8), transparent 24%),
      linear-gradient(180deg, var(--bg-top) 0%, var(--bg-mid) 44%, var(--bg-bottom) 100%);
    color: var(--text);
    font-family: "Avenir Next Rounded", "Trebuchet MS", "Gill Sans", sans-serif;
    overflow: hidden;
    user-select: none;
    -webkit-user-select: none;
  }

  body::before,
  body::after {
    content: "";
    position: fixed;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(8px);
    opacity: 0.72;
  }

  body::before {
    inset: auto auto 14% -12%;
    width: 180px;
    height: 180px;
    background: rgba(255, 255, 255, 0.45);
  }

  body::after {
    inset: 6% -10% auto auto;
    width: 220px;
    height: 220px;
    background: rgba(255, 255, 255, 0.28);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  select {
    font: inherit;
  }

  button:focus-visible,
  input:focus-visible,
  select:focus-visible {
    outline: 2px solid rgba(89, 215, 255, 0.9);
    outline-offset: 3px;
  }

  .screen {
    position: fixed;
    inset: 0;
    display: none;
    flex-direction: column;
    padding:
      calc(env(safe-area-inset-top, 0px) + 18px)
      16px
      calc(env(safe-area-inset-bottom, 0px) + 108px);
    overflow: hidden;
  }

  .screen.active {
    display: flex;
  }

  #finder {
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  body.finder-active .bottom-tabs,
  body.finder-active .fab,
  body.finder-active .save-sheet {
    display: none;
  }

  .shell {
    max-width: 440px;
    width: 100%;
    margin: 0 auto;
  }

  .home-shell {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 0;
    flex: 1;
    overflow-y: auto;
    padding-bottom: 8px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .eyebrow::before {
    content: "";
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    box-shadow: 0 0 0 5px rgba(255, 94, 178, 0.13);
  }

  h1 {
    font-size: clamp(30px, 9vw, 42px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-top: 8px;
  }

  h2 {
    font-size: 18px;
    line-height: 1.1;
  }

  .hero-card,
  .panel,
  .spot-card,
  .finder-panel {
    border: 1px solid rgba(255, 255, 255, 0.68);
    border-radius: 28px;
    background: var(--surface);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .hero-card {
    padding: 18px 18px 20px;
    position: relative;
    overflow: hidden;
  }

  .hero-card::after {
    content: "";
    position: absolute;
    inset: auto -18px -36px auto;
    width: 120px;
    height: 120px;
    border-radius: 28px;
    background: linear-gradient(145deg, rgba(255, 216, 79, 0.78), rgba(255, 94, 178, 0.28));
    transform: rotate(22deg);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 78%;
  }

  .lede {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.5;
    margin-top: 12px;
  }

  .chip-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .chip {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--text);
    font-size: 12px;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.82);
  }

  .tab-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 18px;
    padding: 14px 12px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: var(--surface-strong);
    color: var(--text);
    font-weight: 800;
    box-shadow: 0 10px 28px rgba(175, 106, 180, 0.1);
  }

  .panel {
    padding: 16px;
    position: relative;
  }

  .panel.menu-open {
    z-index: 30;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
  }

  .panel-note {
    color: var(--text-faint);
    font-size: 12px;
    line-height: 1.4;
  }

  .field-grid {
    display: grid;
    gap: 12px;
  }

  .field label {
    display: block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .field input,
  .suggestion-controls select,
  .suggestion-controls input,
  .location-category {
    width: 100%;
    min-height: 48px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--text);
    border: 1px solid rgba(255, 112, 176, 0.18);
    border-radius: 16px;
    padding: 13px 14px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-height: 50px;
    border: none;
    border-radius: 18px;
    font-size: 15px;
    font-weight: 800;
    color: white;
    cursor: pointer;
    background: linear-gradient(135deg, var(--accent), #ff8a85);
    box-shadow: 0 14px 26px rgba(255, 94, 178, 0.26);
  }

  .btn:disabled {
    opacity: 0.55;
    box-shadow: none;
  }

  .btn.ghost {
    color: var(--text);
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 112, 176, 0.16);
    box-shadow: none;
  }

  .btn.find {
    background: linear-gradient(135deg, var(--accent-2), #36d3a0);
  }

  .btn.spark {
    background: linear-gradient(135deg, var(--accent-3), #ffb84f);
    color: var(--text);
    box-shadow: 0 14px 26px rgba(255, 199, 71, 0.25);
  }

  .status {
    min-height: 18px;
    color: var(--text-dim);
    font-size: 13px;
    line-height: 1.45;
  }

  .status.error {
    color: var(--danger);
  }

  .warn-banner {
    display: none;
    border-radius: 20px;
    padding: 14px 16px;
    border: 1px solid rgba(255, 107, 125, 0.25);
    background: rgba(255, 255, 255, 0.72);
    color: var(--danger);
    font-size: 13px;
    line-height: 1.45;
  }

  .welcome-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
  }

  .welcome-copy p {
    color: var(--text-dim);
    margin-top: 4px;
    font-size: 13px;
  }

  .welcome-copy h2 {
    font-size: 20px;
  }

  .auth-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .auth-actions .btn,
  .welcome-row .btn {
    min-height: 44px;
    font-size: 14px;
  }

  .spot-card {
    margin-top: 0;
    padding: 16px;
    position: relative;
    overflow: visible;
  }

  .spot-card.menu-open {
    z-index: 20;
  }

  .spot-card .name {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }

  .spot-card .meta {
    color: var(--text-dim);
    font-size: 12px;
    margin-top: 7px;
    line-height: 1.55;
  }

  .spot-card .coordinates {
    font-family: "SF Mono", "Monaco", monospace;
    font-size: 11px;
  }

  .spot-card .row {
    display: flex;
    gap: 10px;
    margin-top: 14px;
  }

  .spot-card .row .btn {
    max-width: 180px;
  }

  .spot-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .card-menu {
    position: relative;
    flex: 0 0 auto;
  }

  .card-menu-trigger {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    border: 1px solid rgba(255, 112, 176, 0.16);
    background: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(175, 106, 180, 0.08);
  }

  .card-menu-trigger span {
    transform: translateY(-2px);
  }

  .card-menu-panel {
    position: absolute;
    top: 48px;
    right: 0;
    width: min(250px, 72vw);
    padding: 12px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 40px rgba(130, 92, 160, 0.18);
    display: none;
    gap: 10px;
    z-index: 10;
    min-width: 220px;
  }

  .card-menu.open .card-menu-panel {
    display: grid;
  }

  .menu-action {
    width: 100%;
    border: none;
    background: rgba(255, 255, 255, 0.7);
    color: var(--text);
    text-align: left;
    padding: 12px 14px;
    border-radius: 14px;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid rgba(255, 112, 176, 0.12);
  }

  .menu-action.danger {
    color: var(--danger);
  }

  .menu-label {
    font-size: 12px;
    font-weight: 800;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: -2px;
  }

  .saved-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .saved-header .btn {
    width: auto;
    padding: 0 16px;
    min-height: 42px;
  }

  .fab {
    position: fixed;
    right: 18px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 96px);
    z-index: 30;
    width: 64px;
    height: 64px;
    border-radius: 22px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    font-size: 32px;
    line-height: 1;
    box-shadow: 0 20px 38px rgba(255, 94, 178, 0.32);
    cursor: pointer;
  }

  .save-sheet {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 92px);
    z-index: 25;
    max-width: 440px;
    margin: 0 auto;
    display: none;
  }

  .save-sheet.open {
    display: block;
  }

  .save-sheet .panel {
    padding: 18px;
  }

  #locationPortal {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .spot-cards-container,
  .suggestion-results {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: visible;
  }

  .suggestion-panel {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .suggestion-controls,
  .suggestion-actions {
    display: grid;
    gap: 10px;
  }

  .suggestion-score {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--text-dim);
    font-size: 12px;
    margin-top: 10px;
  }

  .suggestion-score span {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
  }

  .finder-shell {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 100%;
    height: auto;
    padding-top: 58px;
    padding-bottom: 12px;
  }

  .finder-floating-controls {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    z-index: 2;
  }

  .finder-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .finder-badge {
    padding: 10px 14px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    font-size: 12px;
    font-weight: 800;
    color: var(--accent);
    border: 1px solid rgba(255, 255, 255, 0.85);
  }

  .finder-panel {
    flex: 0 0 auto;
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 14px;
    padding: 18px;
    text-align: center;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.7)),
      radial-gradient(circle at top right, rgba(89, 215, 255, 0.18), transparent 40%);
  }

  .finder-name {
    font-size: 30px;
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .finder-subtitle {
    color: var(--text-dim);
    font-size: 13px;
    margin-top: 6px;
  }

  .stage {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 0;
    padding: 8px 0;
  }

  .compass-ring {
    width: min(72vw, 320px);
    aspect-ratio: 1;
    border-radius: 50%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.72)),
      radial-gradient(circle at center, rgba(89, 215, 255, 0.2), transparent 60%);
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 0 0 10px rgba(255, 255, 255, 0.45),
      0 22px 55px rgba(135, 129, 190, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .compass-ring::before,
  .compass-ring::after {
    content: "";
    position: absolute;
    inset: 18px;
    border-radius: 50%;
    border: 1px dashed rgba(255, 94, 178, 0.22);
  }

  .compass-ring::after {
    inset: 42px;
    border-color: rgba(89, 215, 255, 0.22);
  }

  #arrowWrap {
    width: min(42vw, 172px);
    height: min(42vw, 172px);
    will-change: transform;
    filter: drop-shadow(0 14px 20px rgba(255, 94, 178, 0.22));
  }

  #arrowWrap svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #pulse {
    display: none;
    width: 122px;
    height: 122px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-2), var(--success));
    box-shadow: 0 0 0 0 rgba(89, 215, 255, 0.45);
    animation: pulse 1.6s ease-out infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(89, 215, 255, 0.45); }
    100% { box-shadow: 0 0 0 46px rgba(89, 215, 255, 0); }
  }

  .readout {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .readout .dist {
    font-size: clamp(42px, 14vw, 62px);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.05em;
  }

  .readout .dist .unit {
    color: var(--text-dim);
    font-size: 0.45em;
    font-weight: 800;
    margin-left: 6px;
    letter-spacing: 0;
  }

  .readout .dir {
    font-size: 18px;
    color: var(--text-dim);
    min-height: 24px;
  }

  .readout .dir b {
    color: var(--text);
  }

  .readout .fine {
    font-size: 12px;
    color: var(--text-faint);
    min-height: 16px;
  }

  .finder-vote {
    display: none;
    padding: 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.8);
  }

  .finder-vote p {
    color: var(--text-dim);
    font-size: 13px;
    margin-bottom: 10px;
  }

  .finder-vote .row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .round {
    width: 54px;
    min-height: 54px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.84);
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    font-size: 20px;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(175, 106, 180, 0.1);
  }

  .round.on {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    color: white;
  }

  .footnote {
    color: var(--text-faint);
    font-size: 11px;
    line-height: 1.45;
  }

  .share-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(74, 47, 103, 0.24);
    backdrop-filter: blur(10px);
    z-index: 999;
  }

  .share-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(92vw, 380px);
    background: var(--surface-strong);
    border: 1px solid rgba(255, 255, 255, 0.86);
    border-radius: 28px;
    padding: 20px;
    z-index: 1000;
    box-shadow: 0 20px 50px rgba(130, 92, 160, 0.24);
    max-height: 78vh;
    overflow: hidden;
  }

  .share-modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .share-modal h3 {
    font-size: 20px;
    margin-bottom: 4px;
  }

  .share-modal-copy {
    color: var(--text-dim);
    font-size: 13px;
    line-height: 1.45;
  }

  .share-close {
    width: 42px;
    min-width: 42px;
    min-height: 42px;
    border-radius: 14px;
    border: 1px solid rgba(255, 112, 176, 0.14);
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    font-size: 20px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: none;
  }

  .share-search {
    width: 100%;
    min-height: 48px;
    margin-bottom: 14px;
    padding: 13px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 112, 176, 0.18);
    background: rgba(255, 255, 255, 0.92);
    color: var(--text);
  }

  .share-modal .friend-list {
    list-style: none;
    display: grid;
    gap: 10px;
    margin-bottom: 14px;
    max-height: min(48vh, 360px);
    overflow-y: auto;
    padding-right: 4px;
  }

  .share-modal .friend-list li {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.84);
  }

  .share-friend-meta {
    min-width: 0;
  }

  .share-friend-name {
    font-size: 15px;
    font-weight: 800;
    line-height: 1.2;
  }

  .share-friend-note {
    margin-top: 4px;
    color: var(--text-faint);
    font-size: 12px;
    line-height: 1.4;
  }

  .share-modal .friend-list .btn {
    width: auto;
    min-height: 42px;
    padding: 0 14px;
    font-size: 13px;
    flex: 0 0 auto;
  }

  .share-empty {
    color: var(--text-faint);
    font-size: 13px;
    text-align: center;
    padding: 18px 8px 8px;
  }

  .bottom-tabs {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 20;
  }

  .tab-bar {
    max-width: 440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    padding: 10px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 45px rgba(129, 106, 177, 0.15);
  }

  .tab-item {
    flex-direction: column;
    padding: 12px 8px;
    min-height: 64px;
    font-size: 12px;
    line-height: 1.15;
  }

  .tab-icon {
    font-size: 18px;
  }

  .tab-item.active {
    background: linear-gradient(135deg, rgba(255, 94, 178, 0.92), rgba(89, 215, 255, 0.92));
    color: white;
    border-color: transparent;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .screen {
      padding-left: 24px;
      padding-right: 24px;
    }

    .home-shell {
      gap: 16px;
    }

    .suggestion-controls,
    .suggestion-actions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-card,
    .panel,
    .spot-card,
    .finder-panel {
      border-radius: 32px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pulse {
      animation: none;
    }
  }
</style>
</head>
<body>

<div class="screen active" id="home">
  <div class="shell home-shell">
    <section class="hero-card">
      <div class="hero-copy">
        <div class="eyebrow">Waypoint</div>
        <h1>Discover with us.</h1>
        <p class="lede">See where Waypoint takes you.</p>
      </div>
    </section>

    <div class="warn-banner" id="httpsWarn">
      This page is not on HTTPS, so the browser blocks GPS and compass access. Open it through a secure URL when testing on mobile hardware.
    </div>

    <div class="spot-card" id="spotCard" style="display:none">
      <div class="name" id="cardName"></div>
      <div class="meta" id="cardMeta"></div>
      <div class="row">
        <button class="btn find" id="findBtn" type="button">Find</button>
        <button class="btn ghost" id="deleteBtn" type="button">Delete</button>
      </div>
    </div>

    <section class="panel suggestion-panel">
      <div class="panel-header">
        <div>
          <h2>Find new spots</h2>
        </div>
      </div>

      <div class="suggestion-controls">
        <div>
          <label for="suggestCategory">Category</label>
          <select id="suggestCategory" name="suggestCategory">
            <option value="all">Any public spot</option>
            <option value="hidden_gem">Hidden gem</option>
            <option value="local_secret">Only locals know</option>
            <option value="attraction">Attraction</option>
            <option value="food">Food</option>
            <option value="drink">Drink</option>
            <option value="entertain">Entertainment</option>
            <option value="nature">Nature</option>
            <option value="quiet">Quiet spot</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="maxDistance">Max distance (km)</label>
          <input id="maxDistance" name="maxDistance" type="number" min="0.1" step="0.1" value="5">
        </div>
      </div>

      <div class="suggestion-actions">
        <div class="status" id="suggestionStatus"></div>
        <button class="btn find" type="button" onclick="suggestLocations()">Suggest</button>
      </div>

      <div class="suggestion-results" id="suggestionResults"></div>
    </section>

    <p class="footnote">GPS is best outdoors with a clear view of the sky. Once you are close, switch from compass-following to looking around the area.</p>
  </div>
</div>

<div class="save-sheet" id="saveSheet">
  <section class="panel">
    <div class="panel-header">
      <div>
        <div class="eyebrow">Save</div>
        <h2>Drop a new waypoint</h2>
      </div>
      <div class="panel-note">Save points and revisit your list without crowding the main screen.</div>
    </div>

    <div class="field-grid">
      <div class="field">
        <label for="spotName">Spot name</label>
        <input id="spotName" name="spotName" type="text" placeholder="Parked bike, cafe, campsite..." maxlength="40" autocomplete="off" required>
      </div>
      <button class="btn spark" id="saveBtn" onclick="saveLocation()" type="button">Save this spot</button>
      <div class="status" id="homeStatus"></div>
    </div>

    <div class="saved-header" style="margin-top: 16px;">
      <div>
        <div class="eyebrow">Collection</div>
        <h2>Saved locations</h2>
      </div>
      <button id="loadLocation" class="btn ghost" type="button" onclick="loadLocations()">Refresh</button>
    </div>
    <div id="locationPortal">Tap refresh to load your saved spots.</div>
  </section>
</div>

<div class="screen" id="finder">
  <div class="shell finder-shell">
    <div class="finder-floating-controls">
      <button class="round" id="closeBtn" aria-label="Back to main screen">←</button>
      <button class="round" id="beepBtn" aria-label="Toggle sound">🔊</button>
    </div>

    <div class="finder-top">
      <div>
        <div class="eyebrow">Compass Mode</div>
        <div class="finder-name" id="findingName">spot</div>
        <div class="finder-subtitle">Minimal readout for quick mobile navigation.</div>
      </div>
      <div class="finder-badge">Live</div>
    </div>

    <section class="finder-panel">
      <div class="readout">
        <div class="dist" id="distText">— <span class="unit"></span></div>
        <div class="dir" id="dirText">locating…</div>
        <div class="fine" id="fineText"></div>
      </div>

      <div class="stage">
        <div class="compass-ring">
          <div id="arrowWrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="arrowGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#59d7ff"/>
                  <stop offset="55%" stop-color="#ff5eb2"/>
                  <stop offset="100%" stop-color="#ffd84f"/>
                </linearGradient>
              </defs>
              <path d="M50 85 L50 18 M24 43 L50 15 L76 43"
                    stroke="url(#arrowGradient)" stroke-width="14"
                    stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
          <div id="pulse"></div>
        </div>
      </div>

      <div class="finder-vote" id="finderVotePanel">
        <p id="finderVoteText">Worth the trip?</p>
        <div class="row">
          <button class="btn find" type="button" onclick="voteCurrentDestination(1)">Upvote</button>
          <button class="btn ghost" type="button" onclick="voteCurrentDestination(-1)">Downvote</button>
        </div>
      </div>
    </section>
  </div>
</div>

<nav class="bottom-tabs" aria-label="Primary">
  <div class="tab-bar">
    <a class="tab-item active" href="/">
      <span class="tab-icon">🧭</span>
      <span>Compass</span>
    </a>
    <a class="tab-item" href="/drops">
      <span class="tab-icon">📍</span>
      <span>Drops</span>
    </a>
    <a class="tab-item" href="/friend">
      <span class="tab-icon">👥</span>
      <span>Social</span>
    </a>
    <a class="tab-item" href="/account">
      <span class="tab-icon">⚙️</span>
      <span>Account</span>
    </a>
  </div>
</nav>

<button class="fab" id="saveFab" type="button" aria-label="Add new waypoint">+</button>

<script type="module" src="/index.js"></script>
<script>
(() => {
  "use strict";

  const $ = id => document.getElementById(id);

  const store = {
    mem: {},
    get(k) { try { return localStorage.getItem(k); } catch (e) { return this.mem[k] ?? null; } },
    set(k, v) { try { localStorage.setItem(k, v); } catch (e) { this.mem[k] = v; } },
    del(k) { try { localStorage.removeItem(k); } catch (e) { delete this.mem[k]; } }
  };
  const KEY = "waypoint.spot";

  let spot = null;
  let me = null;
  let heading = null;
  let haveCompass = false;
  let watchId = null;
  let saveWatchId = null;
  let rafId = null;
  let shownAngle = 0;
  let arrived = false;
  let beepOn = false;
  let beepTimer = null;
  let audioCtx = null;
  let wakeLock = null;
  let lastDistance = null;

  const R = 6371000;
  const toRad = d => d * Math.PI / 180;

  function distanceM(a, b) {
    const dLat = toRad(b.lat - a.lat), dLng = toRad(b.lng - a.lng);
    const x = Math.sin(dLat / 2) ** 2 +
      Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) * Math.sin(dLng / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(x), Math.sqrt(1 - x));
  }

  function bearingDeg(a, b) {
    const dLng = toRad(b.lng - a.lng);
    const y = Math.sin(dLng) * Math.cos(toRad(b.lat));
    const x = Math.cos(toRad(a.lat)) * Math.sin(toRad(b.lat)) -
              Math.sin(toRad(a.lat)) * Math.cos(toRad(b.lat)) * Math.cos(dLng);
    return (Math.atan2(y, x) * 180 / Math.PI + 360) % 360;
  }

  function setHomeStatus(msg, isError) {
    const el = $("homeStatus");
    el.textContent = msg || "";
    el.classList.toggle("error", !!isError);
  }

  function renderSpotCard() {
    const card = $("spotCard");
    if (!spot) { card.style.display = "none"; return; }
    card.style.display = "block";
    $("cardName").textContent = spot.name;
    const when = new Date(spot.ts).toLocaleString();
    $("cardMeta").textContent =
      `Saved ${when} · ±${Math.round(spot.accuracy)} m fix · ` +
      `${spot.lat.toFixed(6)}, ${spot.lng.toFixed(6)}`;
  }

  function loadSpot() {
    const raw = store.get(KEY);
    if (raw) { try { spot = JSON.parse(raw); } catch (e) { spot = null; } }
    renderSpotCard();
  }

  $("saveBtn").addEventListener("click", () => {
    if (!("geolocation" in navigator)) {
      setHomeStatus("This browser has no geolocation support.", true);
      return;
    }
    const btn = $("saveBtn");
    btn.disabled = true;
    btn.textContent = "Getting GPS fix…";
    setHomeStatus("Hold still for a few seconds while we collect your best fix.");

    let best = null;
    let saveDone = false;
    saveWatchId = navigator.geolocation.watchPosition(
      pos => {
        if (!best || pos.coords.accuracy < best.coords.accuracy) best = pos;
        setHomeStatus(`Fix so far: ±${Math.round(best.coords.accuracy)} m`);
      },
      err => {
        finishSave(null, err);
      },
      { enableHighAccuracy: true, maximumAge: 0, timeout: 15000 }
    );
    setTimeout(() => finishSave(best, null), 6000);

    function finishSave(best, err) {
      if (saveDone) return;
      saveDone = true;
      if (saveWatchId !== null) {
        navigator.geolocation.clearWatch(saveWatchId);
        saveWatchId = null;
      }
      btn.disabled = false;
      btn.textContent = "Save this spot";
      if (err && !best) {
        const msgs = {
          1: "Location permission denied. Allow location access in your browser settings and try again.",
          2: "Position unavailable. Step outside or near a window and retry.",
          3: "GPS timed out. Move to open sky and retry."
        };
        setHomeStatus(msgs[err.code] || ("Location error: " + err.message), true);
        return;
      }
      if (!best) {
        setHomeStatus("No GPS fix received. Move outdoors and retry.", true);
        return;
      }
      const name = $("spotName").value.trim() || "My spot";
      spot = {
        name,
        lat: best.coords.latitude,
        lng: best.coords.longitude,
        accuracy: best.coords.accuracy,
        ts: Date.now()
      };
      store.set(KEY, JSON.stringify(spot));
      renderSpotCard();
      setHomeStatus(`Saved "${name}" with a ±${Math.round(best.coords.accuracy)} m fix.`);
    }
  });

  $("deleteBtn").addEventListener("click", () => {
    spot = null;
    store.del(KEY);
    renderSpotCard();
    setHomeStatus("Spot deleted.");
  });

  let compassTier = 0;
  function onOrient(e) {
    if (typeof e.webkitCompassHeading === "number" && !isNaN(e.webkitCompassHeading)) {
      heading = e.webkitCompassHeading;
      compassTier = 2; haveCompass = true;
    } else if (e.absolute === true && typeof e.alpha === "number") {
      heading = (360 - e.alpha) % 360;
      compassTier = 2; haveCompass = true;
    } else if (typeof e.alpha === "number" && compassTier <= 1) {
      heading = (360 - e.alpha) % 360;
      compassTier = 1; haveCompass = true;
    }
  }

  async function startCompass() {
    if (typeof DeviceOrientationEvent !== "undefined" &&
        typeof DeviceOrientationEvent.requestPermission === "function") {
      try {
        const state = await DeviceOrientationEvent.requestPermission();
        if (state !== "granted") return false;
      } catch (e) { return false; }
    }
    window.addEventListener("deviceorientationabsolute", onOrient, true);
    window.addEventListener("deviceorientation", onOrient, true);
    return true;
  }

  function stopCompass() {
    window.removeEventListener("deviceorientationabsolute", onOrient, true);
    window.removeEventListener("deviceorientation", onOrient, true);
    heading = null;
    haveCompass = false;
    compassTier = 0;
  }

  async function startFinder(targetSpot) {
    if (!targetSpot) return;

    spot = targetSpot;
    arrived = false;
    lastDistance = null;
    me = null;
    const showVotes = !!targetSpot.id && !!targetSpot.is_public;

    $("findingName").textContent = spot.name;
    $("distText").innerHTML = "— <span class='unit'></span>";
    $("dirText").textContent = "locating…";
    $("fineText").textContent = "";
    $("finderVotePanel").style.display = showVotes ? "block" : "none";
    $("finderVotePanel").dataset.locationId = targetSpot.id || "";
    $("finderVoteText").textContent = "Worth the trip?";
    $("pulse").style.display = "none";
    $("arrowWrap").style.display = "block";

    const compassOk = await startCompass();

    watchId = navigator.geolocation.watchPosition(
      pos => {
        me = {
          lat: pos.coords.latitude,
          lng: pos.coords.longitude,
          accuracy: pos.coords.accuracy
        };
      },
      err => {
        $("dirText").textContent = "GPS error";
        $("fineText").textContent = err.code === 1
          ? "Location permission denied. Allow it in browser settings."
          : "No GPS signal. Move to open sky.";
      },
      { enableHighAccuracy: true, maximumAge: 1000, timeout: 20000 }
    );

    setTimeout(() => {
      if (!haveCompass && !arrived) {
        $("fineText").textContent = compassOk
          ? "No compass data. Arrow shows north-up guidance."
          : "Compass permission denied. Arrow shows north-up guidance.";
      }
    }, 3000);

    try { wakeLock = await navigator.wakeLock?.request("screen"); } catch (e) {}

    showScreen("finder");
    loop();
  }

  window.startFinderForLocation = startFinder;

  window.addEventListener("load", () => {
    try {
      const pendingSpotJson = sessionStorage.getItem("pendingTargetSpot");
      if (pendingSpotJson) {
        const targetSpot = JSON.parse(pendingSpotJson);
        sessionStorage.removeItem("pendingTargetSpot");
        setTimeout(() => {
          startFinder(targetSpot);
        }, 100);
      }
    } catch (e) {
      console.error("Error loading pending target spot:", e);
    }
  });

  $("findBtn").addEventListener("click", () => {
    if (!spot) return;
    startFinder(spot);
  });

  function showScreen(id) {
    document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
    $(id).classList.add("active");
    document.body.classList.toggle("finder-active", id === "finder");
  }

  $("saveFab").addEventListener("click", () => {
    $("saveSheet").classList.toggle("open");
  });

  function fmtDistance(m) {
    if (m >= 1000) return [(m / 1000).toFixed(2), "km"];
    if (m >= 100) return [Math.round(m), "m"];
    return [m.toFixed(0), "m"];
  }

  function dirWord(rel) {
    if (rel >= 330 || rel < 30) return "straight <b>ahead</b>";
    if (rel >= 30 && rel < 150) return "drift to your <b>right</b>";
    if (rel >= 150 && rel < 210) return "<b>behind</b> you";
    return "drift to your <b>left</b>";
  }

  function loop() {
    rafId = requestAnimationFrame(loop);
    if (!spot || !me) return;

    const dist = distanceM(me, spot);
    lastDistance = dist;
    const brg = bearingDeg(me, spot);
    const arriveRadius = Math.max(12, me.accuracy);

    if (dist <= arriveRadius && !arrived) {
      arrived = true;
      $("arrowWrap").style.display = "none";
      $("pulse").style.display = "block";
      $("dirText").innerHTML = "<b>You are here</b>";
      if (showVotes) {
        $("finderVoteText").textContent = "You made it. Worth the trip?";
      }
      if (navigator.vibrate) navigator.vibrate([120, 80, 120]);
    } else if (dist > arriveRadius * 1.6 && arrived) {
      arrived = false;
      $("pulse").style.display = "none";
      $("arrowWrap").style.display = "block";
      if (showVotes) {
        $("finderVoteText").textContent = "Worth the trip?";
      }
    }

    const [val, unit] = fmtDistance(dist);
    $("distText").innerHTML = `${val} <span class="unit">${unit}</span>`;
    $("fineText").textContent =
      `GPS ±${Math.round(me.accuracy)} m${haveCompass ? "" : " · compass unavailable"}`;

    if (arrived) return;

    const h = haveCompass && heading !== null ? heading : 0;
    const target = (brg - h + 360) % 360;
    const diff = ((target - shownAngle + 540) % 360) - 180;
    shownAngle = (shownAngle + diff * 0.15 + 360) % 360;
    $("arrowWrap").style.transform = `rotate(${shownAngle}deg)`;

    $("dirText").innerHTML = dirWord(target);
  }

  function beepLoop() {
    if (!beepOn) return;
    if (audioCtx && lastDistance !== null) {
      const o = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      o.frequency.value = arrived ? 1320 : 880;
      g.gain.setValueAtTime(0.12, audioCtx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.12);
      o.connect(g).connect(audioCtx.destination);
      o.start();
      o.stop(audioCtx.currentTime + 0.13);
    }
    const d = lastDistance ?? 200;
    const interval = arrived ? 250 : Math.min(2500, Math.max(350, d * 12));
    beepTimer = setTimeout(beepLoop, interval);
  }

  $("beepBtn").addEventListener("click", () => {
    beepOn = !beepOn;
    $("beepBtn").classList.toggle("on", beepOn);
    if (beepOn) {
      if (!audioCtx) {
        const AC = window.AudioContext || window.webkitAudioContext;
        if (AC) audioCtx = new AC();
      }
      audioCtx?.resume?.();
      beepLoop();
    } else {
      clearTimeout(beepTimer);
    }
  });

  $("closeBtn").addEventListener("click", () => {
    if (watchId !== null) { navigator.geolocation.clearWatch(watchId); watchId = null; }
    if (rafId !== null) { cancelAnimationFrame(rafId); rafId = null; }
    clearTimeout(beepTimer);
    beepOn = false;
    $("beepBtn").classList.remove("on");
    stopCompass();
    try { wakeLock?.release?.(); } catch (e) {}
    wakeLock = null;
    showScreen("home");
  });

  if (!window.isSecureContext) $("httpsWarn").style.display = "block";
  loadSpot();
})();
</script>
</body>
</html>
